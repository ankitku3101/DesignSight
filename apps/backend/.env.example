# MongoDB connection string (Atlas free M0 cluster in production, local mongodb:// for dev)
MONGO_URI=mongodb://localhost:27017/designsight

# Port the Express server listens on
PORT=5000

# Comma-free, single origin the frontend is served from — locks down CORS
CORS_ORIGIN=http://localhost:3000

# Google AI Studio API key — requires Prepay billing enabled as of March 2026 for new
# accounts, even at free-tier usage levels. https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id, kept as a config value so swapping models (e.g. after a retirement) is a
# one-line env change, not a code change. gemini-2.5-flash was retired ahead of its
# published shutdown date in July 2026 — gemini-3.5-flash is the current GA replacement.
GEMINI_MODEL=gemini-3.5-flash

# Cloudinary (free tier) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
